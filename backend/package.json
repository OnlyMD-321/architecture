{
  "name": "gestion-ressources-materielles-backend",
  "version": "1.0.0",
  "description": "API backend pour la gestion des ressources matérielles",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "test": "jest --forceExit --detectOpenHandles --verbose",
    "test:unitaire": "jest --testPathPattern=tests/unitaire --forceExit --detectOpenHandles",
    "test:integration": "jest --testPathPattern=tests/integration --forceExit --detectOpenHandles --runInBand"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.13.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.3"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "sqlite3": "^5.1.7",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "verbose": true
  }
}
